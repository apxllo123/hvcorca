{
  "name": "hvcorca",
  "version": "1.1.1",
  "description": "hvcorca - Roblox TS bundle with darklua",
  "main": "main.client.lua",
  "scripts": {
    "build": "rbxtsc",
    "watch": "rbxtsc -w",
    "rojo": "mkdirp dist && rojo build -o dist/main.rbxm",
    "bundle:dev": "pnpm run rojo && cross-env ENV=development remodel run ci/bundle.lua dist/main-dev.lua dev debug",
    "bundle:prod": "pnpm run rojo && cross-env ENV=production remodel run ci/bundle.lua dist/main.lua",
    "bundle": "pnpm run bundle:dev && pnpm run bundle:prod",
    "lint": "eslint src/ --ext .ts,.tsx --fix",
    "lint:ci": "eslint src/ --ext .ts,.tsx --max-warnings 0"
  },
  "keywords": ["roblox", "rbxts", "darklua"],
  "author": "hvcorca (Richie0866 fork)",
  "license": "MIT",
  "devDependencies": {
    "@rbxts/compiler-types": "^3.0.0-types.0",
    "@rbxts/types": "^2.1.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-roblox-ts": "^1.4.0",
    "mkdirp": "^3.0.1",
    "prettier": "^3.0.0",
    "roblox-ts": "^3.0.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@rbxts/roact": "^3.0.1",
    "@rbxts/roact-hooked": "^3.0.0",
    "@rbxts/roact-rodux-hooked": "^2.0.0",
    "@rbxts/rodux": "^3.0.0",
    "@rbxts/services": "^2.1.2",
    "rbxts-transform-debug": "^3.0.0"
  }
}
